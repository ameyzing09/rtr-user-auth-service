{
  "openapi": "3.0.3",
  "info": {
    "title": "RTR User Auth Service API",
    "version": "1.0.0",
    "description": "API documentation for RTR user authentication and tenant configuration service."
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication and user session operations"
    },
    {
      "name": "Users",
      "description": "User management operations for tenant administrators"
    },
    {
      "name": "Tenant Settings",
      "description": "Tenant-level configuration management"
    }
  ],
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:8082",
      "description": "Local development"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Health check",
        "description": "Returns service health status to verify the API is reachable.",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Service is reachable",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "rtr-user-auth-service: ok"
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Authenticate",
        "description": "Authenticates a user with email and password and returns a JWT token.",
        "tags": ["Auth"],
        "parameters": [
          {
            "name": "X-Tenant-Domain",
            "in": "header",
            "description": "Tenant domain for resolving the tenant context. Required if Host header does not already include tenant domain.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated successfully",
            "headers": {
              "X-Tenant-ID": {
                "description": "Resolved tenant identifier assigned to the user.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Get current user",
        "description": "Returns the authenticated user's profile information.",
        "tags": ["Users"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          },
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "User profile returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/me/change-password": {
      "post": {
        "summary": "Change current user's password",
        "description": "Allows the authenticated user to change their password.",
        "tags": ["Users"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          },
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password updated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/users": {
      "get": {
        "summary": "List tenant users",
        "description": "Returns all users belonging to the tenant of the authenticated actor.",
        "tags": ["Users"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          },
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Users returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "post": {
        "summary": "Create user",
        "description": "Creates a new tenant user and returns the generated temporary password.",
        "tags": ["Users"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          },
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateUserResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/tenant/settings": {
      "get": {
        "summary": "Get tenant settings",
        "description": "Returns the tenant configuration for the resolved tenant.",
        "tags": ["Tenant Settings"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant settings returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TenantSettingsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "summary": "Replace tenant settings",
        "description": "Creates or replaces the tenant configuration document.",
        "tags": ["Tenant Settings"],
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantDomainHeader"
          },
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TenantSettingsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tenant settings updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TenantSettingsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "TenantDomainHeader": {
        "name": "X-Tenant-Domain",
        "in": "header",
        "description": "Tenant domain used to resolve tenant context. Optional when the request Host header already contains the tenant domain.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AuthorizationHeader": {
        "name": "Authorization",
        "in": "header",
        "description": "JWT bearer token returned by the login endpoint (e.g. `Bearer eyJ...`).",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "P@ssw0rd!"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "Token": {
            "type": "string",
            "description": "JWT access token"
          },
          "ExpiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Token expiration timestamp"
          },
          "User": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "string",
            "description": "Unique user identifier",
            "example": "1d23f5c6-7890-4abc-def1-234567890abc"
          },
          "TenantID": {
            "type": "string",
            "description": "Tenant identifier the user belongs to"
          },
          "Name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "Email": {
            "type": "string",
            "format": "email",
            "example": "jane@example.com"
          },
          "Role": {
            "type": "string",
            "description": "Assigned role for the user",
            "example": "admin"
          },
          "MustChangePassword": {
            "type": "boolean",
            "description": "Indicates whether user must change the password on next login"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["email", "name", "role"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "new-hire@example.com"
          },
          "name": {
            "type": "string",
            "example": "New Hire"
          },
          "role": {
            "type": "string",
            "enum": ["admin", "hr", "interviewer", "candidate"],
            "example": "hr"
          }
        }
      },
      "CreateUserResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "temporary_password": {
            "type": "string",
            "description": "Generated temporary password for the user"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["current_password", "new_password"],
        "properties": {
          "current_password": {
            "type": "string",
            "format": "password"
          },
          "new_password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "TenantSettingsRequest": {
        "type": "object",
        "required": ["config"],
        "properties": {
          "config": {
            "type": "object",
            "additionalProperties": {}
          }
        }
      },
      "TenantSettingsResponse": {
        "type": "object",
        "properties": {
          "config": {
            "type": "object",
            "additionalProperties": {}
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "email must be a valid email"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication is required or failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "Invalid token"
            }
          }
        }
      },
      "Forbidden": {
        "description": "The authenticated user does not have permission",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "forbidden"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "unknown tenant domain"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflict with current state (e.g., email already in use)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "email already in use for tenant"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Request could not be processed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Unexpected server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "internal server error"
            }
          }
        }
      }
    }
  }
}
